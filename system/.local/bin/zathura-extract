#!/bin/bash
FILE="$1"
PAGE="$2"
ACTION="$3"

# Hash the filename to track page queues for multiple concurrently open PDFs
LIST="/tmp/zathura_$(echo -n "$FILE" | md5sum | cut -d' ' -f1).txt"

if [ "$ACTION" = "mark" ]; then
    echo "$PAGE" >> "$LIST"
    notify-send "Zathura" "Page $PAGE queued."
elif [ "$ACTION" = "export" ]; then
    if [ ! -f "$LIST" ]; then
        notify-send "Zathura Error" "No pages queued for this file."
        exit 1
    fi
    
    # Sort numerically, remove duplicates, and join with commas (e.g., 1,3,5)
    PAGES=$(sort -nu "$LIST" | paste -sd, -)
    OUT="${FILE%.*}_extracted.pdf"
    
    # Extract pages to a new file
    qpdf --empty --pages "$FILE" "$PAGES" -- "$OUT"
    
    rm "$LIST"
    notify-send "Zathura" "Exported pages $PAGES to $(basename "$OUT")"
fi
