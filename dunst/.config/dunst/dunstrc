[global]
    ### Display ###
    monitor = 0
    follow = mouse
    
    ### Geometry ###
    width = 300
    height = (0, 200)
    origin = top-right
    offset = (12, 12)
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    ### Appearance ###
    transparency = 0
    separator_height = 1
    padding = 6
    horizontal_padding = 8
    text_icon_padding = 8
    frame_width = 1
    frame_color = "#b8bb26"
    gap_size = 2
    separator_color = frame
    sort = yes

    ### Text ###
    font = GeistMono Nerd Font 9
    line_height = 0
    markup = full
    format = "<span foreground='#a89984'>[%a]</span>\n<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus-Dark, Adwaita"
    icon_position = left
    min_icon_size = 24
    max_icon_size = 32

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc ###
    dmenu = /usr/bin/tofi --prompt-text "dunst: "
    browser = /usr/bin/firefox -new-tab
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 0
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#1d2021"
    foreground = "#a89984"
    frame_color = "#3c3836"
    timeout = 3

[urgency_normal]
    background = "#1d2021"
    foreground = "#ebdbb2"
    frame_color = "#b8bb26"
    timeout = 5

[urgency_critical]
    background = "#1d2021"
    foreground = "#fb4934"
    frame_color = "#cc241d"
    timeout = 0
    icon = dialog-error

[battery_warning]
    summary = "Battery*"
    format = "<span foreground='#d3869b'>[System]</span>\n<b>%s</b>\n%b"
    frame_color = "#d3869b"
    urgency = critical
