### Settings
# Font configuration
set font "JetBrains Mono normal 12"

# Core options
set selection-clipboard clipboard
set adjust-open "best-fit"
set pages-per-row 1
set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100
set zoom-step 10

# Interface
set guioptions ""
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1

# Render loading
set render-loading "true"
set render-loading-fg "#282c34"
set render-loading-bg "#282c34"

### Colors (Dracula-inspired dark mode friendly)
set default-bg "#282c34"
set default-fg "#f8f8f2"

set statusbar-fg "#f8f8f2"
set statusbar-bg "#44475a"

set inputbar-bg "#282c34"
set inputbar-fg "#f8f8f2"

set notification-error-bg "#ff5555"
set notification-error-fg "#f8f8f2"
set notification-warning-bg "#ffb86c"
set notification-warning-fg "#44475a"
set notification-bg "#282c34"
set notification-fg "#f8f8f2"

set completion-bg "#282c34"
set completion-fg "#6272a4"
set completion-group-bg "#282c34"
set completion-group-fg "#6272a4"
set completion-highlight-bg "#44475a"
set completion-highlight-fg "#f8f8f2"

set index-bg "#282c34"
set index-fg "#f8f8f2"
set index-active-bg "#44475a"
set index-active-fg "#f8f8f2"

### Recolor mode (Toggle with Ctrl+r)
set recolor-lightcolor "#282c34"
set recolor-darkcolor "#f8f8f2"
set recolor "false"
set recolor-keephue "true"
