# ── Basics ────────────────────────────────────────────────────────────────────
set $mod Mod4

# ── Display (fallback — kanshi is source of truth) ────────────────────────────
# output eDP-1 resolution 2880x1800@120Hz scale 2 position 0 540
# output DP-1  resolution 2560x1440@99.946Hz scale 1 position 1440 0
# output DP-2  resolution 1920x1080@60Hz  scale 1 position 4000 1440

# ── Workspace Bindings ────────────────────────────────────────────────────────
workspace 1 output eDP-1
workspace 2 output eDP-1
workspace 3 output eDP-1

workspace 4 output DP-1
workspace 5 output DP-1
workspace 6 output DP-1

workspace 7 output DP-2
workspace 8 output DP-2
workspace 9 output DP-2
# ── Appearance ────────────────────────────────────────────────────────────────
default_border pixel 2
default_floating_border pixel 2
gaps inner 4
gaps outer 0
smart_gaps on
smart_borders on
seat * xcursor_theme Adwaita 24
font pango:GeistMono Nerd Font 12

# Colors:                  border    bg        text      indicator child_border
client.focused             #d79921   #282828   #ebdbb2   #8ec07c   #d79921
client.unfocused           #3c3836   #1d2021   #928374   #3c3836   #3c3836
client.focused_inactive    #3c3836   #282828   #928374   #3c3836   #3c3836
client.urgent              #cc241d   #cc241d   #fbf1c7   #cc241d   #cc241d

# ── Input ─────────────────────────────────────────────────────────────────────
input "type:keyboard" {
    xkb_options compose:ralt
    repeat_delay 250
    repeat_rate 40
}
input "type:touchpad" {
    tap enabled
    natural_scroll disabled
    dwt enabled
}

# ── Window Assignments ────────────────────────────────────────────────────────
# Floating rules for utility windows
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable

# Assign Obsidian
for_window [app_id="obsidian"] move to workspace number 4
# Assign calcurse (targets the specific app_id defined in autostart)
for_window [app_id="calendar"] move to workspace number 9

# ── GTK Theme Enforcement ─────────────────────────────────────────────────────
set $gnome-schema org.gnome.desktop.interface
exec_always {
    gsettings set $gnome-schema gtk-theme 'Arc-Dark'
    gsettings set $gnome-schema color-scheme 'prefer-dark'
    gsettings set $gnome-schema icon-theme 'Papirus-Dark'
    gsettings set $gnome-schema cursor-theme 'Adwaita'
    gsettings set $gnome-schema font-name 'GeistMono Nerd Font 12'
}
# ── Autostart ─────────────────────────────────────────────────────────────────
exec dbus-update-activation-environment --all
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec gnome-keyring-daemon --start --components=secrets
exec swww-daemon
exec dunst
exec fcitx5 -d
exec swayidle -w \
    # timeout 300 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep 'swaylock --config ~/.config/swaylock/config'
exec blueman-applet
exec udiskie -t
exec kanshi &
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec wl-paste --watch cliphist store
# Delay apps that rely on workspace-output assignments (kanshi race)
exec sleep 2 && firefox
exec sleep 2 && obsidian
exec sleep 2 && kitty --class calendar -e calcurse

bar {
    swaybar_command waybar
}
# ── Keybindings — Applications ────────────────────────────────────────────────
bindsym $mod+p exec tofi-drun | xargs swaymsg exec --
bindsym $mod+Shift+Return exec kitty
bindsym $mod+c exec firefox
bindsym $mod+o exec obsidian
bindsym $mod+r exec kitty -e fish -c yazi
# a for appointment
bindsym $mod+a exec kitty --class calendar -e calcurse
bindsym $mod+Shift+s exec bash -c 'D=$HOME/Pictures/Screenshots; mkdir -p "$D"; grim -g "$(slurp)" - | tee "$D/$(date +%Y%m%d_%H%M%S).png" | wl-copy'

# ── Keybindings — WM ──────────────────────────────────────────────────────────
bindsym $mod+b bar mode toggle

# Vim-directional focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+f focus mode_toggle

bindsym $mod+i splith
bindsym $mod+d splitv

mode "resize" {
    bindsym h resize grow width 20px
    bindsym l resize shrink width 20px
    bindsym j resize grow height 20px
    bindsym k resize shrink height 20px
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+Ctrl+r mode "default"
}
bindsym $mod+Ctrl+r mode "resize"

bindsym $mod+Tab workspace back_and_forth
bindsym $mod+Shift+c kill
bindsym $mod+t layout splith
bindsym $mod+Shift+space floating toggle
bindsym $mod+Shift+q exit
bindsym $mod+Escape exec swaylock --config ~/.config/swaylock/config

bindsym $mod+grave move scratchpad
bindsym $mod+Shift+grave scratchpad show

bindsym $mod+comma focus output left
bindsym $mod+period focus output right
bindsym $mod+Shift+comma move container to output left
bindsym $mod+Shift+period move container to output right

# Layouts
bindsym $mod+w layout tabbed
bindsym $mod+s layout stacking
bindsym $mod+e layout toggle split

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

bindsym $mod+0 workspace private
bindsym $mod+Shift+0 move container to workspace private

# Media
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +1%
bindsym XF86MonBrightnessDown exec brightnessctl set 1%-

bindsym $mod+Shift+r exec sway reload;
bindsym $mod+v exec cliphist list | tofi | cliphist decode | wl-copy

floating_modifier $mod normal
