### Core Settings
set font "GeistMono Nerd Font 12"
set selection-clipboard clipboard
set adjust-open "best-fit"
set pages-per-row 1
set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100
set zoom-step 10

### UI Tweaks
set guioptions ""
set statusbar-h-padding 5
set statusbar-v-padding 5
set page-padding 2

### Gruvbox Dark Theme
set default-bg                  "#282828"
set default-fg                  "#ebdbb2"
set statusbar-fg                "#a89984"
set statusbar-bg                "#3c3836"
set inputbar-bg                 "#282828"
set inputbar-fg                 "#ebdbb2"
set notification-error-bg       "#cc241d"
set notification-error-fg       "#ebdbb2"
set notification-warning-bg     "#d79921"
set notification-warning-fg     "#282828"
set notification-bg             "#3c3836"
set notification-fg             "#ebdbb2"
set completion-bg               "#3c3836"
set completion-fg               "#ebdbb2"
set completion-group-bg         "#3c3836"
set completion-group-fg         "#928374"
set completion-highlight-bg     "#83a598"
set completion-highlight-fg     "#282828"
set index-bg                    "#282828"
set index-fg                    "#ebdbb2"
set index-active-bg             "#83a598"
set index-active-fg             "#282828"
set render-loading-bg           "#282828"
set render-loading-fg           "#ebdbb2"

### Recolor Mode (Dark Mode for PDFs)
set recolor-lightcolor          "#282828"
set recolor-darkcolor           "#ebdbb2"
set recolor                     "false"
set recolor-keephue             "true"

### Keybindings
map i recolor
map f toggle_fullscreen
map [normal] <C-i> zoom in
map [normal] <C-o> zoom out
map m exec "/home/joshua/.local/bin/zathura-extract \"$FILE\" $PAGE mark"
map X exec "/home/joshua/.local/bin/zathura-extract \"$FILE\" $PAGE export"
